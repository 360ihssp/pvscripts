local ZERO_VECTOR = Vector3.zero

local isOn, isLocked, killCount, targetPlayer, heartbeatConnection, characterConnection = false, false, 0, nil, nil, nil

local function getCharacter(player)
	return player and player.Character
end

local function getHumanoidRootPart(character)
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(character)
	return character and character:FindFirstChildOfClass("Humanoid")
end

local function isAlive(player)
	if not player or not player.Character then return false end
	local hrp = player.Character:FindFirstChild("HumanoidRootPart")
	local hum = player.Character:FindFirstChildOfClass("Humanoid")
	return hrp ~= nil and hum ~= nil and hum.Health > 0
end

local function setMovementStats(character, walkSpeed, jumpPower)
	local humanoid = getHumanoid(character)
	if humanoid then humanoid.WalkSpeed = walkSpeed; humanoid.JumpPower = jumpPower end
end

local function freezeCharacter(character)
	local rootPart = getHumanoidRootPart(character)
	if not rootPart then return end
	rootPart.AssemblyLinearVelocity  = ZERO_VECTOR
	rootPart.AssemblyAngularVelocity = ZERO_VECTOR
	setMovementStats(character, 0, 0)
end

local function snapToTarget(character)
	if not targetPlayer or not isAlive(targetPlayer) then return end
	local targetCharacter = getCharacter(targetPlayer)
	if not targetCharacter then return end
	local localRootPart  = getHumanoidRootPart(character)
	local targetRootPart = getHumanoidRootPart(targetCharacter)
	if not localRootPart or not targetRootPart then return end
	localRootPart.CFrame = targetRootPart.CFrame
	localRootPart.AssemblyLinearVelocity  = ZERO_VECTOR
	localRootPart.AssemblyAngularVelocity = ZERO_VECTOR
	setMovementStats(character, 0, 0)
end

local function restoreMovement(character)
	setMovementStats(character or Player.Character, 16, 50)
end

local function beginSequence(character)
	isLocked  = true
	killCount = getLeaderstatsKills()
	snapToTarget(character)
	freezeCharacter(character)
end

local function onHeartbeat()
	if not isLocked then return end
	local localCharacter = Player.Character
	if not localCharacter then return end
	local currentKills = getLeaderstatsKills()
	if currentKills > killCount then
		isLocked  = false
		killCount = currentKills
		restoreMovement(localCharacter)
		return
	end
	snapToTarget(localCharacter)
	if targetPlayer and isAlive(targetPlayer) then
		killPlayer(targetPlayer)
	end
end

local function startScript()
	if isOn then return end
	isOn = true
	beginSequence(Player.Character)
	heartbeatConnection = RunService.Heartbeat:Connect(onHeartbeat)
	characterConnection = Player.CharacterAdded:Connect(function(newCharacter)
		if isOn then beginSequence(newCharacter) end
	end)
end

local function stopScript()
	isOn     = false
	isLocked = false
	if heartbeatConnection then heartbeatConnection:Disconnect(); heartbeatConnection = nil end
	if characterConnection  then characterConnection:Disconnect();  characterConnection = nil end
	restoreMovement(Player.Character)
end

