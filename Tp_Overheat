local function unequipAllPets()
	local categories = petsFolder:GetChildren()
	for i = 1, #categories do
		local categoryFolder = categories[i]
		if categoryFolder:IsA("Folder") then
			local pets = categoryFolder:GetChildren()
			for j = 1, #pets do
				equipRemote:FireServer("unequipPet", pets[j])
			end
		end
	end
end

local function getMaxEquippedPets()
	local leaderstats = player:FindFirstChild("leaderstats")
	local maxEquippedValue = leaderstats and leaderstats:FindFirstChild("MaxPetsEquipped")
	if maxEquippedValue then
		return maxEquippedValue.Value
	end
	local fallbackValue = player:FindFirstChild("MaxPetsEquipped")
	if fallbackValue then
		return fallbackValue.Value
	end
	return 8
end

local function playerHasMightyMonster()
	local pets = uniquePetsFolder:GetChildren()
	for i = 1, #pets do
		if pets[i].Name == "Mighty Monster" then
			return true
		end
	end
	return false
end

local function getAllowedPetType()
	if playerHasMightyMonster() then
		return "Mighty Monster"
	end
	return nil
end

local function startPackSpamLoop()
	if loopActive then return end
	loopActive = true
	task.spawn(function()
		while isPackSpamEnabled do
			local maxEquippedPets = getMaxEquippedPets()
			local allowedPetName = getAllowedPetType()
			unequipAllPets()
			task.wait(0.05)
			if allowedPetName then
				local equippedCount = 0
				local pets = uniquePetsFolder:GetChildren()
				for i = 1, #pets do
					local pet = pets[i]
					if pet.Name == allowedPetName then
						equipRemote:FireServer("equipPet", pet)

						equippedCount += 1
						if equippedCount >= maxEquippedPets then
							break
						end
					end
				end
			end
			task.wait(0.05)
		end
		loopActive = false
	end)
end

