local function startWaterLock()
    waterLockActive = true
    local char = Player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = waterLockCFrame end
    end
    waterLockThread = task.spawn(function()
        while waterLockActive do
            local character = Player.Character
            if character then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = waterLockCFrame
                    hrp.Velocity = Vector3.zero
                    hrp.RotVelocity = Vector3.zero
                end
            end
            task.wait(0.03)
        end
    end)
    waterLockCharConn = Player.CharacterAdded:Connect(function(newChar)
        if not waterLockActive then return end
        task.wait(0.05)
        local hrp = newChar:WaitForChild("HumanoidRootPart", 2)
        if hrp then hrp.CFrame = waterLockCFrame end
    end)
end

local function stopWaterLock()
    waterLockActive = false
    if waterLockThread then task.cancel(waterLockThread) waterLockThread = nil end
    if waterLockCharConn then waterLockCharConn:Disconnect() waterLockCharConn = nil end
end

